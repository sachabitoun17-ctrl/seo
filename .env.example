# --- Site ---
# Production URL (no trailing slash). Used for canonical, sitemap, hreflang.
NEXT_PUBLIC_SITE_URL=https://slowmadly.com
NEXT_PUBLIC_SITE_NAME=Slowmadly

# --- Cloudflare Web Analytics ---
# Token from Cloudflare dashboard → Analytics → Web Analytics → Add a site
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# --- Cron ---
# Random secret for /api/cron/* endpoints (Bearer auth from GitHub Actions)
CRON_SECRET=

# --- IndexNow ---
# UUID-style key, also placed at /public/{key}.txt
INDEXNOW_KEY=

# --- Affiliate placeholders (to fill once signups complete) ---
NEXT_PUBLIC_AFF_SAFETYWING=
NEXT_PUBLIC_AFF_TRAVELPAYOUTS=
NEXT_PUBLIC_AFF_VIATOR=

# --- GitHub (used by future data refresh action) ---
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_BRANCH=main

# --- Cloudflare Pages deploy hook (used by GitHub Actions weekly trigger) ---
# Generated in Cloudflare Pages dashboard → Project → Settings → Deploy hooks
CF_PAGES_DEPLOY_HOOK=
