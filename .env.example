# --- Site ---
# Production URL (no trailing slash). Used for canonical, sitemap, hreflang.
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SITE_NAME=Slowmad

# --- Cron ---
# Random secret for /api/cron/* endpoints (Bearer auth)
CRON_SECRET=

# --- IndexNow ---
# UUID-style key, also placed at /public/{key}.txt
INDEXNOW_KEY=

# --- Affiliate placeholders (to fill once signups complete) ---
NEXT_PUBLIC_AFF_SAFETYWING=
NEXT_PUBLIC_AFF_TRAVELPAYOUTS=
NEXT_PUBLIC_AFF_VIATOR=

# --- GitHub (used by data refresh cron to commit data/*.json) ---
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_BRANCH=main
